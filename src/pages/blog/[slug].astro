---
import Whitepaper from '../../layouts/Whitepaper.astro';

const { slug } = Astro.params;

let post: {
  title: string;
  excerpt: string;
  html: string;
  category: string;
  keyword: string;
  lang: string;
  slug: string;
  published_at: string;
  image_url?: string;
} | null = null;

try {
  const res = await fetch(
    `https://api.shadowsoftware.com/ray/blogs/${encodeURIComponent(slug ?? '')}`
  );
  if (res.ok) {
    const data = await res.json();
    if (data && data.slug) post = data;
  }
} catch {}

if (!post) return Astro.redirect('/blog/', 302);

const date = new Date(post.published_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<Whitepaper
  title={`${post.title} — Ray Winkelman`}
  description={post.excerpt}
  lang={post.lang ?? 'en'}
  logo="/ray.png"
  platformName={post.title}
  platformUrl="https://raywinkelman.com/blog/"
  tagline={`${post.category} · ${date}`}
  path={`/blog/${post.slug}/`}
  datePublished={post.published_at}
  showVisitLink={false}
  featuredImage={`/blog-img/${post.slug}.avif`}
>

<Fragment set:html={post.html} />

</Whitepaper>
